# Database — Neon Postgres connection string
# Get this from your Neon project dashboard → Connection Details → Connection string
# Use the pooled connection string for general use
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=verify-full"

# Auth.js secret — used to sign session tokens
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Auth.js URL — set to your local dev URL in .env.local, production URL in Vercel env vars
NEXTAUTH_URL="http://localhost:3000"

# TMDB API Read Access Token (v4 auth) — used for media search, sent as a Bearer token.
# Get one at https://www.themoviedb.org/settings/api (the long JWT-style token, not the v3 API key)
# Never use NEXT_PUBLIC_ — this must remain server-side only
TMDB_API_KEY=""
